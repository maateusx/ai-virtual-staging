# ---- Backend (server) ----
PORT=3333
HOST=0.0.0.0
MONGO_URI=mongodb://127.0.0.1:27017/decorar_ai

# Public base URL used to build temporary image URLs returned by the API
PUBLIC_BASE_URL=http://localhost:3333

# CORS origin of the web app (Vite dev server)
WEB_ORIGIN=http://localhost:5173

# ---- AI provider (Google Gemini "Nano Banana" image model) ----
# Get a key at https://aistudio.google.com/apikey (format: AIza...).
# Optional: if empty, the server has no key and each request must supply its own
# key (BYOK, pasted in the web UI). With no server key and no BYOK, the API
# returns 422. A user-supplied key always takes precedence over this one.
GEMINI_API_KEY=
# Image-capable Gemini model (a.k.a. "Nano Banana"). Override with the current
# model id from the Gemini docs if needed.
GEMINI_MODEL=gemini-3.1-flash-image

# ---- Video generation (Google Veo, image-to-video) ----
# Async flow: a job is created and polled in the background. Reuses GEMINI_API_KEY
# (and BYOK) above — the key must have Veo access. Per-second pricing lives in
# the model registry (server/src/services/video/registry.js), not here.
# Default model offered by the UI.
VIDEO_MODEL=veo-3.1-fast-generate-preview
# How often the server polls the provider for a job's progress (ms).
VIDEO_POLL_INTERVAL_MS=10000
# Hard cap per job before it's marked as errored/timed out (ms).
VIDEO_TIMEOUT_MS=480000

# ---- Cost estimation (optional) ----
# Used to turn the token usage of each generation into an estimated cost
# (USD + BRL), returned in the response and stored on the job. Defaults follow
# Gemini image pricing; override to track the current price sheet without a
# code change.
# USD price per 1,000,000 tokens (input = prompt + input image).
GEMINI_INPUT_USD_PER_M=0.3
# USD price per 1,000,000 output (generated image) tokens.
GEMINI_OUTPUT_USD_PER_M=30
# USD -> BRL conversion rate used for the BRL estimate.
USD_TO_BRL=5.4

# ---- Frontend (web) ----
# Base URL of the backend API, consumed by Vite at build time.
VITE_API_URL=http://localhost:3333
